# cPanel / Apache : le SW et le shell HTML ne doivent pas être servis avec un cache long,
# sinon les déploiements semblent « ne rien changer » malgré des fichiers à jour sur le serveur.
<IfModule mod_headers.c>
  <FilesMatch "^(sw\.js|index\.html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

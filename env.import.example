# Copier vers des variables d'environnement (ne pas committer de secrets).
# Ancien projet (ex. Lovable) : Dashboard Supabase → Settings → Database → Connection string (mode direct, port 5432).
# Nouveau projet : remplace NOUVEAU_PROJECT_REF par la même valeur que VITE_SUPABASE_PROJECT_ID dans ton .env.

SOURCE_DATABASE_URL=postgresql://postgres:VOTRE_MDP@db.ANCIEN_PROJECT_REF.supabase.co:5432/postgres
TARGET_DATABASE_URL=postgresql://postgres:VOTRE_MDP@db.NOUVEAU_PROJECT_REF.supabase.co:5432/postgres

# Import JSON (scripts/import-backup-json.mjs) — clé « service_role », pas l’anon
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# BACKUP_JSON_PATH=C:/Users/.../backup_2026-04-03.json
# USER_ID_MAP_JSON=C:/Users/.../user-id-map.json   # optionnel { "ancien-uuid": "nouvel-uuid" }
